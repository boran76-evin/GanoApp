<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gano.Pages.MainPage">

    <Grid RowDefinitions="*, Auto">
        
        <ScrollView Grid.Row="0">
            
        <VerticalStackLayout Padding="15" Spacing="10">
            
            <Label Text="Dersler" FontSize="24"/>

            <CollectionView x:Name="dersListesi" SelectionMode="Single">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <Border Padding="8" Margin="5"
                                    StrokeShape="RoundRectangle 10">

                            <Grid ColumnDefinitions="5,*">

                            <BoxView WidthRequest="5"
                                     Color="DodgerBlue"
                                     VerticalOptions="Fill"/>

                            <VerticalStackLayout Grid.Column="1"
                                     Padding="10"
                                     Spacing="5">

                            <Label Text="{Binding DersAdi}"
                                    FontSize="16"
                                    FontAttributes="Bold"/>

                            <Label Text="{Binding DersKodu}"
                                   FontSize="12"
                                   TextColor="Gray"/>

                            <Label Text="{Binding AKTS,StringFormat='AKTS: {0:F1}'}" FontSize="12"/>

                            <Label Text="{Binding BasariNotu, StringFormat='Not: {0}'}" FontSize="12"/>

                            <HorizontalStackLayout Spacing="10">

                            <Button Text="Düzenle"
                                FontSize="12"
                                HeightRequest="32"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                CornerRadius="6"
                                Clicked="btnDuzenle_Clicked"/>

                            <Button Text="Sil"
                                FontSize="12"
                                HeightRequest="32"
                                BackgroundColor="#E53935"
                                TextColor="White"
                                CornerRadius="6"
                                Clicked="btnSil_Clicked"/>

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Grid>

                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
        
    <Border Grid.Row="1"
            Padding="15"
            BackgroundColor="#F5F5F5"
            StrokeShape="RoundRectangle 16"
            Margin="10">
        
            <Border.Shadow>
                <Shadow Brush="Black"
                Opacity="0.2"
                Radius="10"
                Offset="2,2"/>
            </Border.Shadow>

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">

                <Label Text="🎓" FontSize="22"/>

                <Label x:Name="ganoLabel"
               Text="GANO: 0.00"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="DodgerBlue"/>

            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentPage>